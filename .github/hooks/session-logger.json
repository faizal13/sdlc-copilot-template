{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node .github/hooks/session-logger/log-session-start.js",
        "timeout": 5
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node .github/hooks/session-logger/log-session-end.js",
        "timeout": 5
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "node .github/hooks/session-logger/log-prompt.js",
        "timeout": 5
      }
    ]
  }
}
